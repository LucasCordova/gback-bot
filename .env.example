# Discord Fact Bot / Cron — copy to .env or set in Railway Variables
# Required for post_fact.py (cron) and fact_bot.py (long-running)

# Discord bot token from https://discord.com/developers/applications → Your App → Bot
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord channel ID (Developer Mode → right-click channel → Copy ID)
CHANNEL_ID=1234567890123456789

# Base URL of your chat API (no trailing slash)
# Local: http://127.0.0.1:8000
# Railway: https://your-chat-service.railway.app
CHAT_API_URL=http://127.0.0.1:8000

# Optional: prompt sent to the chat API (default: Give me a random fact)
# FACT_PROMPT=Give me a random fact

# Optional: only for fact_bot.py (long-running) — minutes between posts
# INTERVAL_MINUTES=60
